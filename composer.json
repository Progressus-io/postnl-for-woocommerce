{
	"name": "postnl/postnl-for-woocommerce",
	"license": "GPL-3.0",
	"type": "wordpress-plugin",
	"require": {
		"clegginabox/pdf-merger": "dev-master",
		"postnl/api-client-sdk": "1.x-dev@dev"
	},
	"autoload": {
		"psr-4": {
			"PostNLWooCommerce\\": "src/"
		}
	},
	"archive": {
		"exclude": [
			"!/assets",
			"!/build",
			"!/vendor",
			"!/languages",
			"/node_modules",
            "/client",
			"bin",
			"tests",
			"README.md",
			"changelog.txt",
			"DEVELOPER.md",
			"package.json",
			"composer.lock",
			"pnpm-lock.yaml",
			"phpunit-unit.xml.dist",
			"phpunit-integration.xml.dist",
			"webpack.config.js",
			"postcss.config.js",
			"phpcs.xml",
			"package-lock.json",
			"composer.json",
			"babel.config.js",
			"jest-puppeteer.config.js",
			".*",
			"auth.json",
			"auth.*.json",
			"*.zip",
			"jest.config.js",
			"AGENTS.md",
			"CLAUDE.md",
			"docs"
		]
	},
	"require-dev": {
		"wp-cli/i18n-command": "^2.6",
		"squizlabs/php_codesniffer": "*",
		"dealerdirect/phpcodesniffer-composer-installer": "*",
		"wp-coding-standards/wpcs": "*",
		"woocommerce/woocommerce-sniffs": "*",
		"phpunit/phpunit": "^10.5",
		"yoast/phpunit-polyfills": "^2.0",
		"brain/monkey": "^2.6"
	},
	"autoload-dev": {
		"psr-4": {
			"PostNLWooCommerce\\Tests\\": "tests/php/"
		}
	},
	"config": {
		"allow-plugins": {
			"dealerdirect/phpcodesniffer-composer-installer": true,
			"php-http/discovery": true
		},
		"phpcs-ignore": ".git,vendor,node_modules,assets,build,tests"
	},
	"scripts": {
		"check-security": [
			"sh -c './vendor/bin/phpcs . --ignore=$(composer config phpcs-ignore) --standard=./.phpcs.security.xml --report-full --report-summary'"
		],
		"check-php": [
			"sh -c './vendor/bin/phpcs . --ignore=$(composer config phpcs-ignore) --standard=./.phpcs.xml --report-full --report-summary --colors'"
		],
		"check-php:fix": [
			"sh -c './vendor/bin/phpcbf . --ignore=$(composer config phpcs-ignore) --standard=./.phpcs.xml --report-full --report-summary --colors'"
		],
		"check-all": [
			"sh -c './vendor/bin/phpcs . --ignore=$(composer config phpcs-ignore) --standard=./.phpcs.xml --report-full --report-summary --colors -s'"
		],
		"check-all:fix": [
			"sh -c './vendor/bin/phpcbf . --ignore=$(composer config phpcs-ignore) --standard=./.phpcs.xml --report-full --report-summary --colors'"
		],
		"check-l18n": [
			"sh -c './vendor/bin/phpcs . --ignore=$(composer config phpcs-ignore) --standard=./.phpcs.l18n.xml --report-full --report-summary --colors -s'"
		],
		"test": [ "composer config name"]
	},
	"repositories": {
		"private-packagist": {
			"type": "composer",
			"url": "https://postnl.repo.packagist.com/progressus/"
		}
	}
}
