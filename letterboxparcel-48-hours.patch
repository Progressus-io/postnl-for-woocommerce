+			$( '#postnl_insured_shipping' ).prop( 'disabled', false );
+			$( '#postnl_return_no_answer' ).prop( 'disabled', false );
+			$( '#postnl_signature_on_delivery' ).prop( 'disabled', false );
+			$( '#postnl_delivery_code_at_door' ).prop( 'disabled', false );
